{
  "name": "compaki",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace compaki-api",
    "dev:web": "npm run dev --workspace compaki-web",
    "build": "npm run build --workspace compaki-web",
    "lint": "npm run lint --workspace compaki-web",
    "typecheck": "npm run typecheck --workspaces",
    "deploy:testnet": "npm run deploy:testnet --workspace compaki-api",
    "demo:purchase": "npm run demo:purchase --workspace compaki-api",
    "demo:seed": "npm run demo:seed --workspace compaki-api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
