// Compaki — Prisma schema v1.
//
// Supabase/Postgres is the production database. A few app-facing fields remain
// intentionally simple for the demo:
//   - User.role is a String constrained in TypeScript (see src/lib/db/types.ts).
//   - Sale.splitSnapshot is stored as a JSON string to keep API code numeric.
//   - *.priceUsd/amountUsd are Float values; switch to Decimal when exact
//     accounting beyond the Stellar settlement layer becomes product-critical.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String?  @unique
  name                   String
  role                   String // "OPERATOR" | "VENDOR" | "BUYER" | "COMMUNITY"
  // scrypt hash ("salt:hash", hex). Null for legacy/custodial-only users, who
  // can claim their account by registering with the same email.
  passwordHash           String?
  country                String?
  stellarPublicKey       String?  @unique
  stellarSecretEncrypted String?
  createdAt              DateTime @default(now())

  marketplaces     Marketplace[]      @relation("MarketplaceOperator")
  communityFundFor Marketplace[]      @relation("MarketplaceCommunityFund")
  products         Product[]          @relation("ProductVendor")
  purchases        Sale[]             @relation("SaleBuyer")
  orders           Order[]            @relation("OrderBuyer")
  vendorMemberships VendorMembership[]
}

model Marketplace {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String   @default("")
  category             String   @default("Other")
  // Revenue split in basis points; must sum to 10_000.
  splitVendorBps       Int      @default(9000)
  splitOperatorBps     Int      @default(1000)
  splitCommunityBps    Int      @default(0)
  // ID of this marketplace inside the shared Soroban contract (null until registered on-chain).
  contractMarketplaceId String? @unique
  // Hash of the create_marketplace transaction — the "verified on-chain" link.
  createTxHash         String?
  regenerativeEnabled  Boolean  @default(false)
  createdAt            DateTime @default(now())

  operatorId String
  operator   User      @relation("MarketplaceOperator", fields: [operatorId], references: [id])
  // Custodial account receiving the community share (role COMMUNITY).
  communityFundId String?
  communityFund   User?  @relation("MarketplaceCommunityFund", fields: [communityFundId], references: [id])
  products   Product[]
  vendors    VendorMembership[]
  orders     Order[]
}

// A vendor's membership in one marketplace (a vendor may have no products yet).
model VendorMembership {
  id               String   @id @default(cuid())
  sellsDescription String   @default("")
  // Hash of the register_vendor transaction on testnet.
  registerTxHash   String?
  createdAt        DateTime @default(now())

  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])

  @@unique([marketplaceId, userId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  // Short description shown on storefront cards; the long one lives on the
  // product detail page.
  shortDescription String @default("")
  description String   @default("")
  priceUsd    Float // demo-grade; Decimal(12,2) when off-chain accounting needs exact math
  // Units the vendor has for sale. Decremented when an order item settles.
  stock       Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())

  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  vendorId      String
  vendor        User        @relation("ProductVendor", fields: [vendorId], references: [id])
  sales         Sale[]
  orderItems    OrderItem[]
}

// A buyer's order, created when they proceed to payment from the cart. Orders
// start PENDING with a 10-minute expiry; paying settles every item on-chain
// and flips the order to COMPLETED. Expiry is applied lazily on read/pay.
model Order {
  id       String   @id @default(cuid())
  status   String   @default("PENDING") // "PENDING" | "COMPLETED" | "EXPIRED"
  totalUsd Float
  // Pending orders die at this instant; only COMPLETED settles stock/money.
  expiresAt DateTime
  // Shipping address captured at checkout (null until paid).
  shipAddress    String?
  shipCity       String?
  shipPostalCode String?
  shipCountry    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  buyerId       String
  buyer         User        @relation("OrderBuyer", fields: [buyerId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id           String @id @default(cuid())
  quantity     Int
  // Price frozen when the order was created, so later product edits don't
  // reprice a pending checkout.
  unitPriceUsd Float

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale?
}

model Sale {
  id            String   @id @default(cuid())
  // Gross amount for the line (unit price × quantity).
  amountUsd     Float
  quantity      Int      @default(1)
  // Stellar transaction hash — links the UI receipt to stellar.expert.
  txHash        String   @unique
  // JSON snapshot of the split applied at purchase time, e.g.
  // {"vendorBps":9000,"operatorBps":800,"communityBps":200,"vendorAmount":...}
  splitSnapshot String
  // Wall-clock seconds the on-chain settlement took — feeds the receipt's
  // "settled in N seconds" trust line. Null for sales predating this field.
  settleSeconds Int?
  // Shipping address captured at checkout. Null for sales predating auth.
  shipAddress    String?
  shipCity       String?
  shipPostalCode String?
  shipCountry    String?
  createdAt     DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id])
  buyerId   String
  buyer     User    @relation("SaleBuyer", fields: [buyerId], references: [id])
  // Cart checkouts settle one sale per order item; null for legacy one-click sales.
  orderItemId String?    @unique
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
}
